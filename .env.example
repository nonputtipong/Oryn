# Gravity Claw — Environment Variables
# Copy this to .env and fill in your values.

# ── Required ──────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# OpenRouter API key from openrouter.ai
OPENROUTER_API_KEY=

# Comma-separated Telegram user IDs allowed to use this bot
# Find yours by messaging @userinfobot on Telegram
ALLOWED_USER_IDS=

# ── Optional (features degrade gracefully without these) ──────────────

# Groq API key — required for voice transcription (Whisper)
GROQ_API_KEY=

# ElevenLabs API key — required for text-to-speech (Talk Mode)
ELEVENLABS_API_KEY=

# ElevenLabs voice ID (default: Rachel)
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Security ──────────────────────────────────────────────────────────

# Master key for AES-256-GCM encrypted secret storage
# MASTER_KEY=

# Enable Docker sandbox for shell commands (true/false)
# SANDBOX_ENABLED=false

# Docker image for sandbox (default: node:20-slim)
# SANDBOX_IMAGE=node:20-slim

# ── Google Workspace (Gmail, Calendar, Drive) ─────────────────────────
# Get these from Google Cloud Console → APIs & Credentials
# Then run: npm run gmail:auth

# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=

# ── Proactive Features ────────────────────────────────────────────────

# Morning briefing time in HH:MM format (default: 07:00)
# BRIEFING_TIME=07:00

# Live Canvas WebSocket port (default: 3001)
# CANVAS_PORT=3001
